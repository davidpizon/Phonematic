<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Phonematic.ViewModels"
             x:Class="Phonematic.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <ScrollViewer>
        <StackPanel Margin="16" Spacing="16" MaxWidth="600">
            <TextBlock Text="Settings" FontSize="20" FontWeight="Bold" />

            <!-- Output Directory -->
            <StackPanel Spacing="4">
                <TextBlock Text="Output Directory" FontWeight="SemiBold" />
                <DockPanel>
                    <Button Content="Browse" Command="{Binding BrowseOutputDirectoryCommand}"
                            DockPanel.Dock="Right" Margin="4,0,0,0" />
                    <TextBox Text="{Binding OutputDirectory}" />
                </DockPanel>
            </StackPanel>

            <!-- Whisper Model Size -->
            <StackPanel Spacing="4">
                <TextBlock Text="Whisper Model Size" FontWeight="SemiBold" />
                <ComboBox ItemsSource="{Binding WhisperModelSizes}"
                          SelectedItem="{Binding SelectedWhisperModel}"
                          HorizontalAlignment="Stretch" />
            </StackPanel>

            <!-- Thread Count -->
            <StackPanel Spacing="4">
                <DockPanel>
                    <TextBlock Text="Thread Count" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding ThreadCount}" HorizontalAlignment="Right" />
                </DockPanel>
                <Slider Value="{Binding ThreadCount}"
                        Minimum="1"
                        Maximum="{Binding MaxThreads}"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True" />
            </StackPanel>

            <!-- Config Directory -->
            <StackPanel Spacing="4">
                <TextBlock Text="Config Directory" FontWeight="SemiBold" />
                <TextBox Text="{Binding ConfigDirectoryPath}" IsReadOnly="True" />
            </StackPanel>

            <!-- Model Status -->
            <StackPanel Spacing="8">
                <TextBlock Text="Models" FontWeight="SemiBold" FontSize="16" />

                <!-- Whisper -->
                <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                        BorderThickness="0,0,0,1" Padding="0,0,0,8">
                    <StackPanel Spacing="4">
                        <DockPanel>
                            <Button Content="Download"
                                    Command="{Binding DownloadWhisperModelCommand}"
                                    IsEnabled="{Binding !IsDownloadingWhisper}"
                                    DockPanel.Dock="Right" Padding="12,4" />
                            <TextBlock Text="{Binding WhisperModelStatus}"
                                       DockPanel.Dock="Right" VerticalAlignment="Center" Margin="8,0" />
                            <TextBlock Text="Whisper (speech-to-text)" VerticalAlignment="Center" />
                        </DockPanel>
                        <ProgressBar Value="{Binding WhisperDownloadProgress}"
                                     Minimum="0" Maximum="1" Height="6"
                                     IsVisible="{Binding IsDownloadingWhisper}" />
                    </StackPanel>
                </Border>

                <!-- ONNX -->
                <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                        BorderThickness="0,0,0,1" Padding="0,0,0,8">
                    <StackPanel Spacing="4">
                        <DockPanel>
                            <Button Content="Download"
                                    Command="{Binding DownloadOnnxModelCommand}"
                                    IsEnabled="{Binding !IsDownloadingOnnx}"
                                    DockPanel.Dock="Right" Padding="12,4" />
                            <TextBlock Text="{Binding OnnxModelStatus}"
                                       DockPanel.Dock="Right" VerticalAlignment="Center" Margin="8,0" />
                            <TextBlock Text="Embedding model (ONNX)" VerticalAlignment="Center" />
                        </DockPanel>
                        <ProgressBar Value="{Binding OnnxDownloadProgress}"
                                     Minimum="0" Maximum="1" Height="6"
                                     IsVisible="{Binding IsDownloadingOnnx}" />
                    </StackPanel>
                </Border>

                <!-- LLM -->
                <StackPanel Spacing="4">
                    <DockPanel>
                        <Button Content="Download"
                                Command="{Binding DownloadLlmModelCommand}"
                                IsEnabled="{Binding !IsDownloadingLlm}"
                                DockPanel.Dock="Right" Padding="12,4" />
                        <TextBlock Text="{Binding LlmModelStatus}"
                                   DockPanel.Dock="Right" VerticalAlignment="Center" Margin="8,0" />
                        <TextBlock Text="LLM (Phi-3)" VerticalAlignment="Center" />
                    </DockPanel>
                    <ProgressBar Value="{Binding LlmDownloadProgress}"
                                 Minimum="0" Maximum="1" Height="6"
                                 IsVisible="{Binding IsDownloadingLlm}" />
                </StackPanel>
            </StackPanel>

            <!-- Version -->
            <DockPanel>
                <TextBlock Text="Version" FontWeight="SemiBold" />
                <TextBlock Text="{Binding AppVersion}" HorizontalAlignment="Right" />
            </DockPanel>

            <!-- Save -->
            <DockPanel>
                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Foreground="Green" />
                <Button Content="Save" Command="{Binding SaveCommand}"
                        HorizontalAlignment="Right" />
            </DockPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
