<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Phonematic.ViewModels"
             x:Class="Phonematic.Views.TrainView"
             x:DataType="vm:TrainViewModel">

    <DockPanel Margin="16">
        <!-- Top: Input path and browse buttons -->
        <StackPanel DockPanel.Dock="Top" Spacing="8">
            <TextBlock Text="Train Voice Model" FontSize="20" FontWeight="Bold" />

            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Browse Folder"
                        Command="{Binding BrowseFolderCommand}" />
                <TextBox Text="{Binding InputPath}" PlaceholderText="Enter folder path..."
                         Margin="0,0,8,0" />
            </DockPanel>
        </StackPanel>

        <!-- Bottom: Progress and controls -->
        <StackPanel DockPanel.Dock="Bottom" Spacing="8" Margin="0,8,0,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4">
                    <Button Content="Start Training"
                            Command="{Binding StartTrainingCommand}"
                            IsEnabled="{Binding !IsTraining}" />
                    <Button Content="Cancel"
                            Command="{Binding StartTrainingCancelCommand}"
                            IsEnabled="{Binding IsTraining}" />
                </StackPanel>
                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" />
            </DockPanel>

            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="Current File:" Margin="0,0,8,0"
                           VerticalAlignment="Center" />
                <ProgressBar Value="{Binding CurrentFileProgress}"
                             Minimum="0" Maximum="1" Height="16" />
            </DockPanel>

            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="Overall:" Margin="0,0,8,0"
                           VerticalAlignment="Center" />
                <ProgressBar Value="{Binding OverallProgress}"
                             Minimum="0" Maximum="1" Height="16" />
            </DockPanel>

            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock>
                    <Run Text="Completed: " /><Run Text="{Binding CompletedCount}" FontWeight="Bold" />
                </TextBlock>
                <TextBlock>
                    <Run Text="Skipped: " /><Run Text="{Binding SkippedCount}" FontWeight="Bold" />
                </TextBlock>
                <TextBlock>
                    <Run Text="Failed: " /><Run Text="{Binding FailedCount}" FontWeight="Bold" />
                </TextBlock>
            </StackPanel>
        </StackPanel>

        <!-- Center: Source Input file list -->
        <StackPanel Margin="0,8,0,0" Spacing="4">
            <TextBlock Text="Source Input" FontWeight="SemiBold" />
            <DataGrid ItemsSource="{Binding Files}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserResizeColumns="True"
                      GridLinesVisibility="Horizontal"
                      BorderBrush="Gray" BorderThickness="1">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding FileName}" Width="2*" />
                    <DataGridTextColumn Header="Size" Binding="{Binding FileSizeDisplay}" Width="Auto" />
                    <DataGridTextColumn Header="Audio" Binding="{Binding AudioExtension}" Width="Auto" />
                    <DataGridTextColumn Header="Transcription" Binding="{Binding TranscriptionStatus}" Width="Auto" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </DockPanel>

</UserControl>
